{
  "name": "@naisys/hub-database",
  "version": "3.0.0",
  "type": "module",
  "description": "[internal] Hub database schema and Prisma client for NAISYS",
  "files": [
    "dist",
    "prisma/schema.prisma",
    "prisma/migrations"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "prisma:migrate": "prisma migrate dev --create-only",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "build": "npm run prisma:generate && tsc",
    "npm:publish:dryrun": "npm publish --dry-run",
    "npm:publish": "npm publish --access public"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@naisys/common": "3.0.0",
    "@naisys/common-node": "3.0.0",
    "@prisma/adapter-better-sqlite3": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "prisma": "^7.5.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  }
}
