{
  "name": "@naisys/common",
  "version": "3.0.0",
  "type": "module",
  "description": "[internal] Common utilities and constants for NAISYS",
  "files": [
    "dist",
    "assets",
    "!dist/**/*.map",
    "!dist/**/*.d.ts",
    "!dist/**/*.d.ts.map"
  ],
  "scripts": {
    "clean": "npx rimraf dist",
    "build": "tsc",
    "npm:publish:dryrun": "npm publish --dry-run",
    "npm:publish": "npm publish --access public"
  },
  "dependencies": {
    "semver": "^7.7.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/semver": "^7.7.1",
    "typescript": "^5.9.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./assets/*": "./assets/*"
  }
}
