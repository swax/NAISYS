{
  "name": "@naisys/common-node",
  "version": "3.0.0",
  "type": "module",
  "description": "[internal] Node-only utilities for NAISYS",
  "files": [
    "dist",
    "!dist/**/*.map",
    "!dist/**/*.d.ts",
    "!dist/**/*.d.ts.map"
