{
  "name": "naisys-monorepo",
  "version": "3.0.0",
  "description": "NAISYS monorepo containing NAISYS core and related applications",
  "private": true,
  "packageManager": "npm@11.11.1",
  "type": "module",
  "workspaces": [
    "packages/common",
    "packages/common-node",
    "packages/common-browser",
    "packages/hub-protocol",
    "packages/hub-database",
    "packages/supervisor-database",
    "apps/erp/shared",
    "apps/supervisor/shared",
    "apps/erp/client",
    "apps/supervisor/client",
    "apps/erp/server",
    "apps/supervisor/server",
    "apps/hub",
    "apps/naisys"
  ],
  "scripts": {
    "clean": "turbo clean && rm -rf .turbo",
    "build": "turbo build bundle",
    "test": "turbo test",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier --write .",
    "publish:dryrun": "npm run clean && npm run build && npm run npm:publish:dryrun --workspaces --if-present",
    "publish:beta": "bash scripts/publish-beta.sh",
    "deprecate:beta": "bash scripts/deprecate-beta.sh",
    "publish:release": "bash scripts/publish-release.sh",
    "updates:check": "npm-check-updates && npm-check-updates --workspaces",
    "updates:apply": "npm-check-updates -u && npm-check-updates --workspaces -u && npm install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/swax/NAISYS.git"
  },
  "keywords": [
    "ai",
    "agent",
    "automation",
    "naisys",
    "monorepo"
  ],
  "author": "John Marshall",
  "license": "MIT",
  "homepage": "https://naisys.org",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "npm-check-updates": "^19.6.3",
    "prettier": "^3.8.1",
    "rimraf": "6.1.3",
    "turbo": "^2.8.16",
    "typescript": "^5.9.3"
  }
}
