{
  "name": "naisys-monorepo",
  "version": "3.0.0",
  "description": "NAISYS monorepo containing NAISYS core and related applications",
  "private": true,
  "packageManager": "npm@11.11.1",
  "type": "module",
  "workspaces": [
    "packages/common",
    "packages/common-node",
    "packages/common-browser",
    "packages/hub-protocol",
    "packages/hub-database",
    "packages/supervisor-database",
    "apps/erp/shared",
    "apps/supervisor/shared",
    "apps/erp/client",
    "apps/supervisor/client",
    "apps/erp/server",
    "apps/supervisor/server",
    "apps/hub",
    "apps/naisys"
  ],
  "scripts": {
    "clean": "npx turbo clean && rm -rf .turbo",
    "build": "npx turbo build bundle",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier --write .",
    "test": "npx turbo test",
    "coverage:full": "npm run build && node scripts/run-coverage.mjs",
    "updates:check": "npm-check-updates && npm-check-updates --workspaces",
    "updates:apply": "npm-check-updates -u && npm-check-updates --workspaces -u && npm install && npm audit fix",
    "release:check": "npm install && npm audit --omit=dev --audit-level=high && npm run build && npm run test",
    "release:dryrun": "npm run clean && npm run build && npm run npm:publish:dryrun --workspaces --if-present"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/swax/NAISYS.git"
  },
  "keywords": [
    "ai",
    "agent",
    "automation",
    "naisys",
    "monorepo"
  ],
  "author": "John Marshall",
  "license": "MIT",
  "homepage": "https://naisys.org",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "c8": "^11.0.0",
    "eslint": "^10.0.3",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "istanbul-lib-coverage": "^3.2.2",
    "npm-check-updates": "^19.6.3",
    "prettier": "^3.8.1",
    "rimraf": "6.1.3",
    "shx": "^0.4.0",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3"
  }
}
