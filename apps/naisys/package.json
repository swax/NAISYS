{
  "name": "naisys",
  "description": "NAISYS - Autonomous AI agent runner with built-in context management and cost tracking",
  "version": "3.0.0",
  "type": "module",
  "main": "dist/naisys.js",
  "preferGlobal": true,
  "bin": {
    "naisys": "bin/naisys.js"
  },
  "scripts": {
    "build/run/attachable": "tsc && node --inspect dist/naisys.js ../../agents/assistant.yaml --supervisor",
    "agent:assistant": "node dist/naisys.js ../../agents/assistant.yaml --integrated-hub --supervisor --erp",
    "agent:scdb:program-director": "cd ../../agents/scdb && node ../../apps/naisys/dist/naisys.js program-director.yaml",
    "clean": "rimraf dist",
    "build": "tsc",
    "eslint": "npx eslint src",
    "test": "vitest run",
    "npm:publish:dryrun": "npm publish --dry-run",
    "npm:publish": "npm publish",
    "postinstall": "node -e \"process.platform !== 'win32' && require('child_process').execSync('chmod +x ./bin/*')\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/swax/NAISYS.git"
  },
  "keywords": [
    "ai",
    "agent",
    "automation",
    "cli-tools",
    "devops-tools",
    "naisys"
  ],
  "author": "John Marshall",
  "license": "MIT",
  "homepage": "https://naisys.org",
  "devDependencies": {
    "@naisys/hub-database": "3.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/text-table": "^0.2.5",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "@naisys/hub": "3.0.0"
  },
  "peerDependenciesMeta": {
    "@naisys/hub": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/genai": "^1.45.0",
    "@naisys/common": "3.0.0",
    "@naisys/common-node": "3.0.0",
    "@naisys/hub-protocol": "3.0.0",
    "@xterm/headless": "^6.0.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "js-yaml": "^4.1.1",
    "openai": "^6.27.0",
    "pino": "^10.3.1",
    "sharp": "^0.34.5",
    "socket.io-client": "^4.8.3",
    "string-argv": "^0.3.2",
    "strip-ansi": "^7.2.0",
    "text-table": "^0.2.0",
    "tiktoken": "^1.0.22",
    "tree-kill": "^1.2.2"
  }
}
