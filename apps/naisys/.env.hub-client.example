# Minimal config for connecting to a remote hub (naisys --hub=https://...)
# API keys, spend limits, and variables are managed on the hub.

# Copy value from Supervisor admin page or hub server's NAISYS_FOLDER/cert/hub-access-key
HUB_ACCESS_KEY=

NAISYS_FOLDER="~/.naisys"

# Custom hostname, defaults to machine name
NAISYS_HOSTNAME=

