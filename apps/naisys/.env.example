# Agent home files and NAISYS specific databases will be stored here
NAISYS_FOLDER="~/.naisys"

# Custom hostname, defaults to machine name
NAISYS_HOSTNAME=

# Leave api keys blank if not using the service
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# Used by llmynx to search the web
GOOGLE_SEARCH_ENGINE_ID= 

# These spend limits apply to all agents using this .env file, or override in the agent yaml for per-agent spend limits
SPEND_LIMIT_DOLLARS=20  # Global spend limit across all agents using this .env file
SPEND_LIMIT_HOURS=24 # Time period for spend limits apply in, not a sliding window. If not set then no time limit.

# Integrated supervisor configuration if the --supervisor option is used on startup
SUPERVISOR_PORT=3001
PUBLIC_READ=false

# Integrated Hub configuration if the --integrated-hub option is used on startup
HUB_PORT=3101
# Only needed when connecting to a remote hub (--hub=https://...). Value is the cert fingerprint printed at hub startup.
HUB_ACCESS_KEY=


# Custom global vars for use in agent configurations here
