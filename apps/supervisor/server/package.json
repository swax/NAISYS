{
  "name": "@naisys/supervisor",
  "version": "3.0.0",
  "description": "NAISYS Supervisor - Web UI for monitoring agents, logs, and messaging",
  "type": "module",
  "main": "dist/supervisorServer.js",
  "bin": {
    "naisys-supervisor": "bin/naisys-supervisor.js"
  },
  "exports": {
    ".": "./dist/supervisorServer.js"
  },
  "scripts": {
    "clean": "npx rimraf dist client-dist",
    "dev": "tsx watch src/supervisorServer.ts",
    "start": "node dist/supervisorServer.js",
    "build": "tsc",
    "bundle": "npx shx rm -rf client-dist && npx shx cp -r ../client/dist client-dist",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "npm:publish:dryrun": "npm publish --dry-run",
    "npm:publish": "npm publish --access public"
  },
  "files": [
    "dist",
    "client-dist",
    "bin",
    ".env.example",
    "!dist/**/*.map",
    "!dist/**/*.d.ts",
    "!dist/**/*.d.ts.map",
    "!dist/**/tests",
    "!dist/**/*.test.*"
  ],
  "peerDependencies": {
    "@naisys/erp": "3.0.0"
  },
  "peerDependenciesMeta": {
    "@naisys/erp": {
      "optional": true
    }
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.0.0",
    "@fastify/swagger": "^9.7.0",
    "@naisys/supervisor-shared": "3.0.0",
    "@naisys/common": "3.0.0",
    "@naisys/common-node": "3.0.0",
    "@naisys/hub-database": "3.0.0",
    "@naisys/hub-protocol": "3.0.0",
    "@naisys/supervisor-database": "3.0.0",
    "@scalar/fastify-api-reference": "^1.48.7",
    "@types/archiver": "^7.0.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.2",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "fastify-type-provider-zod": "^6.1.0",
    "js-yaml": "^4.1.1",
    "pino-pretty": "^13.1.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
