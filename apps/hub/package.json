{
  "name": "@naisys/hub",
  "version": "3.0.0",
  "description": "NAISYS Hub - Adds persistence and multi-instance coordination to NAISYS",
  "type": "module",
  "main": "dist/naisysHub.js",
  "bin": {
    "naisys-hub": "bin/naisys-hub.js"
  },
  "exports": {
    ".": "./dist/naisysHub.js",
    "./services/hubServerLog": "./dist/services/hubServerLog.js",
    "./services/runnerServer": "./dist/services/runnerServer.js"
  },
  "scripts": {
    "clean": "npx rimraf dist",
    "dev": "tsx watch src/naisysHub.ts",
    "start": "node dist/naisysHub.js",
    "build": "tsc",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "npm:publish:dryrun": "npm publish --dry-run",
    "npm:publish": "npm publish --access public"
  },
  "files": [
    "npm-shrinkwrap.json",
    "dist",
    "bin",
    ".env.example",
    "!dist/**/*.map",
    "!dist/**/*.d.ts",
    "!dist/**/*.d.ts.map"
  ],
  "peerDependencies": {
    "@naisys/supervisor": "3.0.0"
  },
  "peerDependenciesMeta": {
    "@naisys/supervisor": {
      "optional": true
    }
  },
  "dependencies": {
    "@naisys/common": "3.0.0",
    "@naisys/common-node": "3.0.0",
    "@naisys/hub-database": "3.0.0",
    "@naisys/hub-protocol": "3.0.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
