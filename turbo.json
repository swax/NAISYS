{
  "$schema": "https://v2-9-6.turborepo.dev/schema.json",
  "globalPassThroughEnv": [
    "NODE_V8_COVERAGE",
    "COVERAGE",
    "COVERAGE_CLIENT_RAW_DIR"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "bundle": {
      "outputs": ["client-dist/**"]
    },
    "@naisys/erp#bundle": {
      "dependsOn": ["@naisys/erp-client#build", "@naisys/erp#build"]
    },
    "@naisys/supervisor#bundle": {
      "dependsOn": [
        "@naisys/supervisor-client#build",
        "@naisys/supervisor#build"
      ]
    },
    "clean": {
      "cache": false
    },
    "test": {
      "dependsOn": ["build", "^build"],
      "cache": false
    }
  }
}
